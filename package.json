{
  "name": "financial-agent",
  "private": true,
  "version": "0.0.1",
  "description": "Personal investment research agent — core packages, skills, and contracts. Phase 1: research/monitoring only, no execution capability.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "health-report": "tsx scripts/health-report.ts",
    "journal": "tsx scripts/journal.ts",
    "valuation": "tsx scripts/valuation.ts",
    "options-payoff": "tsx scripts/options-payoff.ts",
    "reports:validate": "tsx scripts/validate-report.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
